# OneGodian API environment template
# Copy this file to .env locally or configure these variables in the production host.
# Never commit real secrets.

NODE_ENV=production
PORT=3000
APP_URL=https://api.onegodian.org

# Keep production origins specific.
# If multiple origins are needed, migrate API code to CORS_ORIGINS comma-separated allowlist.
CORS_ORIGIN=https://onegodian.org

# Healthcheck base URL used by npm run health.
HEALTHCHECK_URL=https://api.onegodian.org

# Stripe integration placeholders.
# Current app reports stripe_configured when STRIPE_SECRET_KEY is present.
# Real Checkout Session creation and webhook signature verification remain production tasks.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Future persistence/auth placeholders.
DATABASE_URL=
JWT_SECRET=
SESSION_SECRET=
